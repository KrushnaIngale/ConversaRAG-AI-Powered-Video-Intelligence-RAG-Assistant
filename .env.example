# Fastest option for this app: groq
# Supported values: groq, gemini, mistral
LLM_PROVIDER=groq

# Groq LLM
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Gemini LLM
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_THINKING_BUDGET=0

# Mistral LLM
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Sarvam AI API Key
SARVAM_API_KEY=

# Optional LangSmith Tracking
LANGCHAIN_API_KEY=
